{
  "name": "nix-config (flake devShell)",
  "image": "mcr.microsoft.com/devcontainers/base:debian",

  "features": {
    "ghcr.io/devcontainers/features/nix:1": {
      "version": "latest",
      "multiUser": true,
      "extraNixConfig": "experimental-features = nix-command flakes"
    },
    // Persists Claude Code state across container rebuilds via per-container
    // Docker NAMED VOLUMES (claude-dir-${devcontainerId}, claude-json-...) —
    // no host bind, no host-path dependency, so a missing path can't crash the
    // container. Defaults persist ~/.claude (history/sessions/todos) but NOT
    // ~/.claude.json (auth), so you re-login after a rebuild; set
    // "persistClaudeJson": true if you want auth to survive too. This repo's
    // project memory (memory/, CLAUDE.md, .claude/) is already shared via the
    // workspace bind mount — this only adds session-state persistence.
    "ghcr.io/esimkowitz/devcontainer-features/claude-code-persistence:1": {},
    // Installs the Claude Code CLI. The published :1 feature installs via nvm,
    // so the binary lands under /usr/local/share/nvm/current/bin/claude
    // (verified in-container, claude 2.1.x) — this backs the "claude" terminal
    // profile below. Also bundles the anthropic.claude-code extension (already
    // listed in extensions, harmless duplicate).
    "ghcr.io/devcontainers-extra/features/claude-code:1": {},
    // Official gh CLI at /usr/bin/gh (default installDirectlyFromGitHubRelease:
    // true → official .deb, avoids the apt-keyserver failure path). No mounts /
    // host paths, so no crash risk. Installs only the binary — auth is a runtime
    // `gh auth login` concern. This also satisfies the `gh` binary the chezmoi
    // gitconfig's `!gh auth git-credential` credential helper depends on; it does
    // NOT write gitconfig, so it can't clash with the chezmoi-managed identity.
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  "workspaceFolder": "/workspaces/nix-config",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/nix-config,type=bind,consistency=cached",

  // Prebuild the flake devShell so the first `nix develop` is fast. Enter the
  // devShell manually with `nix develop` (direnv auto-load was removed).
  "updateContentCommand": "nix develop --command true",

  "containerEnv": {
    "NIXPKGS_ALLOW_UNFREE": "1"
  },

  "customizations": {
    "vscode": {
      // Installed into the container on create. The host only RECOMMENDS these
      // (see ../.vscode/extensions.json) — they need nix + the devShell to work,
      // which lives here in the container, not on the nix-less host.
      "extensions": [
        "jnoortheen.nix-ide",
        "gruntfuggly.triggertaskonsave",
        "fuadpashayev.bottom-terminal",
        "Anthropic.claude-code",
        "shd101wyy.markdown-preview-enhanced"
      ],
      // Container-scoped settings.json. These reference nixd/nixfmt, which come
      // from the flake devShell — only meaningful where nix exists.
      "settings": {
        // --- Nix language server (nix-ide → nixd) ---
        "nix.enableLanguageServer": true,
        "nix.serverPath": "nixd",
        "nix.formatterPath": "nixfmt",
        "nix.serverSettings": {
          "nixd": {
            "formatting": { "command": ["nixfmt"] }
          }
        },

        // --- Format on save, nix-ide owns .nix files ---
        "editor.formatOnSave": true,
        "[nix]": {
          "editor.defaultFormatter": "jnoortheen.nix-ide"
        },

        // --- Live statix/deadnix diagnostics on save (Problems tab) ---
        // On .nix save, runs the "nix: lint" task (../.vscode/tasks.json), whose
        // problem matchers feed statix (anti-patterns) + deadnix (dead code) into
        // Problems — the gap nix-ide/nixd don't cover. Needs triggertaskonsave.
        "triggerTaskOnSave.on": true,
        "triggerTaskOnSave.showNotifications": false,
        "triggerTaskOnSave.tasks": {
          "nix: lint": ["**/*.nix"]
        },

        // --- Terminal profiles (ported from takeoff-api-infra, sans psql) ---
        // The devcontainers-extra/claude-code feature installs via nvm, so the
        // claude binary lives under the nvm prefix. Use the `current` symlink
        // (current -> versions/node/<ver>), NOT a hardcoded version dir, so the
        // path survives node version bumps. Verified in-container (claude 2.1.x).
        "terminal.integrated.profiles.linux": {
          "zsh": {
            "path": "/usr/bin/zsh"
          },
          "claude": {
            "path": "/usr/local/share/nvm/current/bin/claude",
            "args": ["--permission-mode", "bypassPermissions"],
            "icon": "claude",
            "color": "terminal.ansiYellow"
          }
        }
      }
    }
  },

  "remoteUser": "vscode"
}
