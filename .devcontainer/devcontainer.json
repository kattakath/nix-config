{
  // nix-config devcontainer: a PREBUILT, Nix-built image. The whole toolchain —
  // a working multi-user nix (flakes + public Cachix), the warm devShell
  // closure (nixd/nixfmt/treefmt/statix/deadnix/home-manager), node, claude-code,
  // gh — is baked into the image by this repo's flake.nix
  // (packages/devcontainer-image.nix, dockerTools.streamLayeredImage) and
  // published multi-arch to GHCR by .github/workflows/build-devcontainer.yml.
  // Inside the container, `nix develop` resolves from the baked, DB-registered
  // /nix/store: no build, no download.
  //
  // This file keeps ONLY what an image cannot carry: the workspace mount, the
  // VS Code extensions/settings, and the terminal profiles.
  //
  // Published under the short, unnamespaced ghcr.io/ismailkattakath/devcontainer
  // name (this is the repo's sole/default devcontainer).
  "name": "nix-config (prebuilt Nix devcontainer image)",
  "image": "ghcr.io/ismailkattakath/devcontainer:latest",
    
  // Multi-user Nix: the image runs as ROOT (entrypoint starts the nix-daemon) and
  // VS Code drops to the non-root `vscode` user, which reaches the daemon over the
  // socket (NIX_REMOTE=daemon, baked in). Full rationale — why the store stays
  // root-owned, no chown/sudo — lives in packages/devcontainer-image.nix.
  "remoteUser": "vscode",

  // The image ships a fixed uid/gid 1000 vscode user via fakeNss (read-only
  // /etc/passwd), so VS Code's default UID-remap (usermod) can't run — disable it.
  "updateRemoteUserUID": false,

  // Respect the image ENTRYPOINT (which launches nix-daemon then execs the
  // keepalive Cmd). With the default (true) VS Code would replace it and the
  // daemon would never start.
  "overrideCommand": false,

  "workspaceFolder": "/workspaces/nix-config",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/nix-config,type=bind",

  // IMPORTANT: no mount over /nix — that would shadow the baked, warm store the
  // image ships. The container's own overlay makes /nix/store writable for new
  // builds. Project memory (`memory/`) rides the workspaceMount bind (gitignored,
  // host<->container). No volume for ~/.claude (deliberate — don't re-add one).

  "customizations": {
    "vscode": {
      // anthropic.claude-code is registered by the baked claude-code toolchain.
      "extensions": [
        "jnoortheen.nix-ide",
        "gruntfuggly.triggertaskonsave",
        "fuadpashayev.bottom-terminal",
        "shd101wyy.markdown-preview-enhanced",
        "ms-azuretools.vscode-containers"
      ],
      "settings": {
        // nixd/nixfmt resolve from the baked PATH.
        "nix.enableLanguageServer": true,
        "nix.serverPath": "nixd",
        "nix.formatterPath": "nixfmt",
        "nix.serverSettings": {
          "nixd": {
            "formatting": { "command": ["nixfmt"] }
          }
        },

        "editor.formatOnSave": true,
        "[nix]": {
          "editor.defaultFormatter": "jnoortheen.nix-ide"
        },

        // On .nix save, run the "nix: lint" task (statix/deadnix -> Problems).
        "triggerTaskOnSave.on": true,
        "triggerTaskOnSave.showNotifications": false,
        "triggerTaskOnSave.tasks": {
          "nix: lint": ["**/*.nix"]
        },

        // Default terminal enters the flake devShell so the pinned
        // nixd/nixfmt/statix/deadnix are on PATH (the on-convention alternative
        // to direnv). Because the closure is baked, `nix develop` is instant.
        // "zsh" is the recovery shell if a broken flake eval fails the devShell.
        "terminal.integrated.defaultProfile.linux": "nix develop",
        "terminal.integrated.profiles.linux": {
          "bash": { "path": "bash" },
          "nix develop": {
            "path": "bash",
            "args": ["-lc", "exec nix develop"],
            "icon": "beaker"
          },
          "claude": {
            "path": "claude",
            "args": ["--permission-mode", "bypassPermissions"],
            "icon": "claude",
            "color": "terminal.ansiYellow"
          }
        }
      }
    }
  }
}
