{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "outputStyle": "nix-declarative",
  "parallelTasksCount": 4,
  "enableAllProjectMcpServers": true,
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash(git add:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git commit:*)",
      "Bash(nix flake check:*)",
      "Bash(nix flake show:*)",
      "Bash(nix flake update:*)",
      "Bash(nix fmt:*)",
      "Bash(nix develop:*)",
      "Bash(nix-instantiate:*)",
      "Bash(statix check:*)",
      "Bash(deadnix:*)",
      "Bash(home-manager build:*)",
      "Bash(home-manager generations:*)",
      "Bash(utmctl:*)",
      "Bash(osascript:*)",
      "Bash(plutil:*)",
      "Bash(qemu-img:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(sshpass:*)",
      "Bash(ssh-keygen:*)",
      "Bash(ssh-keyscan:*)",
      "Bash(rsync:*)",
      "Bash(age:*)",
      "Bash(curl:*)",
      "Bash(dig:*)",
      "Bash(host:*)",
      "Bash(nc:*)",
      "Bash(ping:*)",
      "Bash(arp:*)",
      "Bash(brew:*)",
      "Bash(open:*)",
      "Bash(cloudflared:*)",
      "Bash(nixos-rebuild:*)",
      "Bash(nixos-install:*)",
      "Bash(nixos-enter:*)",
      "Bash(parted:*)",
      "Bash(mkfs.fat:*)",
      "Bash(mkfs.ext4:*)",
      "Bash(lsblk:*)",
      "Bash(blkid:*)",
      "Bash(wipefs:*)",
      "Bash(udevadm:*)",
      "Bash(sudo:*)",
      "Agent(platform-compiler)",
      "Agent(vm-provisioner)",
      "Agent(nix-researcher)",
      "Agent(ci-release-driver)",
      "Agent(Explore)",
      "Agent(Plan)",
      "Agent(general-purpose)",
      "mcp__context7__*",
      "mcp__duckduckgo__*",
      "mcp__fetch__*",
      "mcp__sequentialthinking__*",
      "mcp__memory__*",
      "mcp__json-yaml-toml__*",
      "mcp__mcp-jq__*",
      "mcp__desktop-commander__*"
    ],
    "deny": [
      "Bash(home-manager switch:*)",
      "Bash(rm -rf:*)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/superhook.js\" UserPromptSubmit -- node \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/delegate-team.js\"",
            "timeout": 15
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "command -v nix >/dev/null 2>&1 && echo 'nix present: full multi-system flake check available locally.' || echo 'nix ABSENT on host: local checks are syntax-only; full aarch64-darwin/x86_64-linux/aarch64-linux evaluation is CI-deferred to Garnix (garnix.yaml).'; u=$(cd \"${CLAUDE_PROJECT_DIR:-.}\" && git ls-files --others --exclude-standard -- '*.nix' 2>/dev/null); [ -n \"$u\" ] && echo \"WARNING: untracked .nix files present — run 'git add -A' before evaluating:\" && echo \"$u\" || true",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/superhook-digest.js\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/memory-loader.js\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Validate this file write for a Nix mono-repo. Deny if: it writes a hardcoded secret/token/private key into a .nix file (the store is world-readable — patterns to block: 'BEGIN PRIVATE KEY', 'BEGIN RSA PRIVATE KEY', 'BEGIN OPENSSH PRIVATE KEY', 'BEGIN EC PRIVATE KEY', tokens like 'ghp_', 'glpat-', 'sk-ant-', 'AKIA', 'sk-'), uses a path-traversal sequence (../), or targets a system path outside the project. APPROVE (never block) SSH public keys — strings starting with 'ssh-ed25519 AAAA', 'ssh-rsa AAAA', or 'ecdsa-sha2-nistp' are intentionally public and are the standard NixOS way to configure openssh.authorizedKeys.keys; they pose no security risk. Approve otherwise.",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/autostage-nix.js\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/superhook.js\" Stop -- node \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/stop-gate.js\"",
            "timeout": 60
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Only applies to subagents that performed Nix flake / Home-Manager EVALUATION (e.g. the platform-compiler agent). If this subagent evaluated Nix, verify it reported results for all three target systems (aarch64-darwin, x86_64-linux, aarch64-linux) and return {\"decision\":\"block\",\"reason\":\"...\"} if a system was skipped. If the subagent did NO Nix evaluation (e.g. search, planning, documentation, or memory tasks), return {\"decision\":\"approve\"}.",
            "timeout": 20
          }
        ]
      }
    ]
  }
}
