# Claude Code — personal overrides and worktree scratch
.claude/settings.local.json
*.local.md
.claude/worktrees/
.worktrees/

# superhook runtime artifacts
.claude/hooks/superhook.log
.claude/hooks/.superhook-state.json

# Project memory — candid, local-only record of decisions/reasoning/findings/values.
# Gitignored on purpose: this is the "why" behind the repo, not committed documentation.
memory/

# macOS Finder cruft
.DS_Store
.DS_Store?
.AppleDouble
._*
tmp

# Nix build artifacts
result
result-*
# nix-direnv's cache dir — direnv itself was removed from this repo, but the
# devcontainer (or any stray nix-direnv run) can still regenerate .direnv/.
# Ignored as a generated artifact so `git add -A` never sweeps it into a commit.
.direnv/

# Disk / VM images — built locally, never committed
*.qcow2
*.img
*.iso
*.vmdk
*.ova
*.utm


# git-hooks.nix generates this from flake.nix on `nix develop` — never commit it
.pre-commit-config.yaml

# Secrets and local env
.env
.env.local
.env.*.local
*.pem
*.key
*.crt
*.secrets

# Terraform / OpenTofu — generated by the terranix cf-litellm-apply app.
# State can contain the tunnel token + Access service-token secret, so it must
# NEVER be committed. The provider lock is machine/arch-specific and re-created
# by `tofu init`, so we gitignore it too rather than pin it here.
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl
