# Copy to `.env` (which is gitignored) and fill in. NEVER commit `.env`.
# docker-compose.yml loads this via `env_file: .env`.

# ── Upstream provider ────────────────────────────────────────────────────────
# Upstream provider key the litellm proxy uses to call OpenAI. Baked config
# references it as os.environ/OPENAI_API_KEY. (sk-…)  SECRET.
OPENAI_API_KEY=

# ── LiteLLM master key (server-only) ─────────────────────────────────────────
# The LiteLLM master key. It stays SERVER-ONLY — do NOT distribute it. Humans use
# Google SSO; API clients use per-key VIRTUAL KEYS issued from the Admin UI
# (safer than sharing the master key). Baked config references it as
# os.environ/LITELLM_MASTER_KEY. Choose a strong random value (sk-…).  SECRET.
LITELLM_MASTER_KEY=

# ── Postgres (backs the Admin UI, virtual keys, spend tracking, SSO users) ────
# The Admin UI + virtual keys REQUIRE a database. The compose file runs a
# `postgres` service on the internal network; these three seed it.
POSTGRES_DB=litellm
POSTGRES_USER=litellm
# Strong random password for the Postgres role above.  SECRET.
POSTGRES_PASSWORD=

# Connection string LiteLLM uses (general_settings.database_url -> os.environ/…).
# Host is the docker-DNS name `postgres`; must embed the same DB/USER/PASSWORD as
# above. Contains the password, so it is SECRET — never commit.
# Example: postgresql://litellm:<POSTGRES_PASSWORD>@postgres:5432/litellm
DATABASE_URL=postgresql://litellm:<POSTGRES_PASSWORD>@postgres:5432/litellm

# ── Google Workspace SSO (Admin UI browser login) ────────────────────────────
# OAuth 2.0 Web client from Google Cloud (project kattakath-family). The client's
# Authorized redirect URI MUST be https://litellm.kattakath.com/sso/callback and
# JS origin https://litellm.kattakath.com (already configured).
# GOOGLE_CLIENT_ID is public (an app identifier); GOOGLE_CLIENT_SECRET is SECRET.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Public base URL LiteLLM uses to build the SSO redirect. MUST match the Google
# client's redirect origin. Not secret.
PROXY_BASE_URL=https://litellm.kattakath.com

# Restrict Admin-UI SSO to your Google Workspace domain — only @kattakath.com
# emails may sign in. Mirrors the Cloudflare Access email-domain allow policy.
ALLOWED_EMAIL_DOMAINS=kattakath.com

# (Optional) Promote the FIRST admin. Log in once via SSO, copy your user_id from
# the LiteLLM UI, paste it here, then restart the litellm container — your role
# becomes proxy_admin. Leave blank on first bring-up. Not secret.
PROXY_ADMIN_ID=

# (Optional) Persist UI-added models to the DB across restarts. Defaults to True
# in the compose file if unset. Not secret.
STORE_MODEL_IN_DB=True

# ── Cloudflare Tunnel + Access ───────────────────────────────────────────────
# Cloudflare Tunnel connector token, from `tofu output -raw tunnel_token` after
# `nix run .#cf-litellm-apply`. Consumed by the cloudflared container.
# SECRET — paste, never commit.
TUNNEL_TOKEN=

# Cloudflare Access service-token client id, from
# `tofu output -raw service_token_client_id` after `nix run .#cf-litellm-apply`.
# INFORMATIONAL here (the container does not read it) — API clients send it as
# the CF-Access-Client-Id request header. The matching CF-Access-Client-Secret
# is printed alongside and is NOT stored here; keep it in your client's secrets.
CF_ACCESS_CLIENT_ID=
