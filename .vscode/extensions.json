{
  // HOST-side recommendations only. This file exists so that opening the repo
  // directly in VSCode (e.g. to "Reopen in Container") prompts to install the
  // extensions the devcontainer needs. The actual editor settings + on-save
  // wiring live in ../.devcontainer/devcontainer.json (customizations.vscode),
  // because they reference nixd/nixfmt from the flake devShell — which only
  // exist inside the container, not on the nix-less host.
  //
  // Keep this list in sync with devcontainer.json's customizations.vscode.extensions.
  "recommendations": [
    "ms-vscode-remote.remote-containers", // "Reopen in Container" — the intended entry point
    "jnoortheen.nix-ide", // Nix language support; drives the nixd LSP (in-container)
    "gruntfuggly.triggertaskonsave", // runs the statix/deadnix lint tasks on save → Problems tab
    "fuadpashayev.bottom-terminal",
    "anthropic.claude-code",
    "shd101wyy.markdown-preview-enhanced" // Markdown renderer (in-editor preview)
  ]
}