# direnv: auto-load the flake devShell on `cd` into the repo, so the editor
# (via the direnv extension) and the shell both get nixd, treefmt, and the
# installed pre-commit hooks without a manual `nix develop`.
#
# We load nix-direnv's `use flake` instead of direnv's built-in one. nix-direnv
# CACHES the evaluated devShell in .direnv/ and only re-evaluates when flake.nix
# or flake.lock change (it adds the right watch_file rules). The built-in loader
# re-evaluates on every reload — and each eval differs just enough that the
# VSCode direnv extension keeps seeing a "changed environment" and prompts to
# restart, an endless loop. Caching breaks that loop at the source.
#
# source_url is pinned to a tagged release + sha256 so the fetched direnvrc is
# reproducible and tamper-evident (direnv refuses a hash mismatch). Bump both
# together from https://github.com/nix-community/nix-direnv releases.
#
# The `has nix` guard skips everything on hosts without a nix toolchain (e.g.
# the macOS host) and points the user at the devcontainer where nix lives; run
# `direnv allow` once.
if has nix; then
  source_url "https://raw.githubusercontent.com/nix-community/nix-direnv/3.1.2/direnvrc" "sha256-Di03ad3a0ueGi6CGrfhrQzyGdQIg9APXIPCAMNQgWYM="
  use flake
else
  log_status "⚠ nix not found — install nix or reopen repo in devcontainer"
fi
